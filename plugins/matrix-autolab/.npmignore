# Never publish local dependencies or build output.
**/node_modules/
**/.next/
**/.turbo/
**/dist/
**/build/
**/coverage/

# Never publish local experiment data, logs, checkpoints, or model weights.
/.autolab/
/logs/
/runs/
/outputs/
**/wandb/
**/lightning_logs/
**/tensorboard/
**/mlruns/
**/checkpoints/
*.ckpt
*.pt
*.pth
*.onnx
*.safetensors

# Never publish credentials or local machine configuration.
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Python and editor caches.
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.vscode/
.idea/

# Codex/dev local artifacts.
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
